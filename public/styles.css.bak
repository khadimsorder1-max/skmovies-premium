/* ============================================================================
   SKMovies — Premium Production-Grade UI v3.0.0
   Full overhaul: glassmorphism, full-bleed hero backdrop, minimalist download buttons,
   grid-based screenshot viewer, full responsiveness.
   ============================================================================ */

/* ─── Design Tokens ──────────────────────────────────────────────────── */
:root {
  --font-primary: 'Exo', 'Segoe UI', system-ui, -apple-system, sans-serif;
  --font-secondary: 'Noto Sans', 'Segoe UI', system-ui, -apple-system, sans-serif;

  /* Brand Colors */
  --red: #fb1114;
  --red-dark: #c50003;
  --red-glow: 0 0 20px rgba(251, 17, 20, 0.4);

  /* Neutrals */
  --black: #08090c;
  --white: #ffffff;
  --grey: #64748b;

  /* Light Mode */
  --bg: #faf7f2;
  --card-bg: #ffffff;
  --border: #e6e0d5;
  --text: #1b1c1e;
  --text-muted: #7c7267;

  /* Dark Mode */
  --bg-dark: #0d0f14;
  --card-bg-dark: #161b26;
  --card-border-dark: rgba(255, 255, 255, 0.06);
  --text-dark: #f1f5f9;
  --text-muted-dark: #94a3b8;

  /* Accents & States */
  --gold: #fbbf24;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.05), 0 1px 2px rgba(0,0,0,0.03);
  --shadow-card: 0 4px 12px rgba(15, 23, 42, 0.05), 0 1px 4px rgba(15, 23, 42, 0.02);
  --shadow-card-hover: 0 12px 30px rgba(251,17,20,0.12);
  --shadow-card-dark-hover: 0 12px 35px rgba(251,17,20,0.18);
  --shadow-modal: 0 20px 50px rgba(0, 0, 0, 0.4);

  /* Borders & Radius */
  --radius-sm: 6px;
  --radius: 12px;
  --radius-lg: 16px;
  --radius-pill: 99px;
  --ease: cubic-bezier(0.2, 0.8, 0.2, 1);
  --maxw: 1160px;
}

/* ─── Reset ──────────────────────────────────────────────────────────── */
*, ::after, ::before { box-sizing: border-box; }
* { margin: 0; padding: 0; }
html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
[hidden] { display: none !important; }

body {
  font-size: 14px;
  line-height: 1.6;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-secondary);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  transition: background 0.3s, color 0.3s;
}

.dark-ui body { background: var(--bg-dark); color: var(--text-dark); }
.dark-ui h1, .dark-ui h2, .dark-ui h3, .dark-ui h4, .dark-ui h5, .dark-ui h6 { color: var(--text-dark); }
.dark-ui p { color: var(--text-muted-dark); }

img { display: block; max-width: 100%; height: auto; }
button { font: inherit; cursor: pointer; background: none; border: none; color: inherit; -webkit-tap-highlight-color: transparent; }
input { font: inherit; color: inherit; }
a { color: inherit; text-decoration: none; }
a:hover { color: var(--red); }
::selection { background: var(--red); color: #fff; }

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.15); border-radius: 10px; }
.dark-ui ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }
::-webkit-scrollbar-thumb:hover { background: var(--red); }

/* ─── Containers ──────────────────────────────────────────────────────── */
.container { width: 100%; padding: 0 20px; margin: 0 auto; max-width: var(--maxw); }
.container-fluid { width: 100%; }

.skip-link { position: absolute; left: -999px; top: 0; background: var(--red); color: #fff; padding: 8px 16px; z-index: 100; font-weight: bold; }
.skip-link:focus { left: 0; }

/* ─── Premium Header ──────────────────────────────────────────────────── */
.site-header {
  position: relative;
  background: radial-gradient(circle at top right, rgba(251, 17, 20, 0.08), transparent 45%), var(--card-bg);
  border-bottom: 1px solid var(--border);
  transition: background 0.3s;
  z-index: 80;
}
.dark-ui .site-header {
  background: radial-gradient(circle at top right, rgba(251, 17, 20, 0.06), transparent 40%), var(--bg-dark);
  border-bottom-color: var(--card-border-dark);
}
.site-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 100%);
  pointer-events: none;
}

/* Menu toggle button */
.menu-toggle {
  display: none;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: var(--radius-sm);
  background: rgba(0,0,0,0.03);
  color: var(--text);
  border: 1px solid var(--border);
  transition: all 0.2s ease;
  cursor: pointer;
  outline: none;
  flex-shrink: 0;
  margin-right: 8px;
}
.dark-ui .menu-toggle {
  background: rgba(255,255,255,0.04);
  color: var(--text-dark);
  border-color: var(--card-border-dark);
}
.menu-toggle:hover {
  background: rgba(251,17,20,0.05);
  color: var(--red);
}

/* Brand bar */
.header-brand {
  max-width: var(--maxw);
  margin: 0 auto;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header-logo img {
  height: 38px;
  width: auto;
  display: block;
}
.header-controls {
  display: flex;
  align-items: center;
  gap: 16px;
}

/* Toggle Wrapper & Mode Switcher */
.toggle-wrap {
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
}
.toggle-icon { font-size: 14px; opacity: 0.8; }
.toggleWrapper { display: inline-block; height: 18px; position: relative; }
.toggleWrapper input { position: absolute; left: -99em; }
.toggle { cursor: pointer; display: inline-block; position: relative; width: 36px; height: 18px; background-color: #cbd5e1; border-radius: 50px; transition: background-color 200ms ease; }
.dark-ui .toggle { background-color: var(--red); }
.toggle__handler { display: inline-block; position: relative; z-index: 1; top: -6px; left: -10px; width: 18px; height: 18px; background-color: #ffcf96; border-radius: 50px; box-shadow: 0 1px 4px rgba(0,0,0,0.2); transition: all 300ms cubic-bezier(.68,-.55,.265,1.55); transform: rotate(-45deg); }
.dark-ui .toggle__handler { transform: rotate(45deg) translate(7px, -7px); background-color: #fff; }

/* 18+ filter */
.filterWrapper { position: relative; cursor: pointer; }
.filterWrapper input { position: absolute; inset: 0; height: 100%; width: 100%; margin: 0; opacity: 0; cursor: pointer; z-index: 2; }
.filterWrapper .filterButton {
  background: rgba(244,67,54,0.1);
  border: 1px solid rgba(244,67,54,0.3);
  padding: 3px 10px;
  border-radius: var(--radius-pill);
  color: #ef4444;
  font-size: 11px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: all 0.2s;
}
.filterWrapper input:checked + .filterButton {
  background: rgba(34,197,94,0.1);
  border-color: rgba(34,197,94,0.3);
  color: #22c55e;
}

/* Notice marquee strip */
.notice-strip {
  background: #0f172a;
  padding: 5px 20px;
  position: relative;
  overflow: hidden;
  border-top: 1px solid rgba(255,255,255,0.04);
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.notice-strip-label {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  background: var(--red);
  color: #fff;
  font-family: var(--font-primary);
  font-weight: 800;
  font-size: 10px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  padding: 0 12px;
  display: flex;
  align-items: center;
  z-index: 3;
}
.notice-strip marquee, #noticeMarquee {
  color: rgba(255,255,255,0.7);
  font-size: 12px;
  padding-left: 90px;
  display: block;
  font-weight: 500;
}

/* Sticky search bar + nav bar */
.nav-bar {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  transition: background 0.3s;
}
.dark-ui .nav-bar {
  background: rgba(13, 15, 20, 0.85);
  border-bottom-color: var(--card-border-dark);
}
.nav-bar__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  min-height: 52px;
}

/* Search form */
.search-form {
  flex: 1;
  max-width: 320px;
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(0,0,0,0.04);
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: var(--radius-pill);
  padding: 6px 14px;
  transition: all 0.2s var(--ease);
}
.dark-ui .search-form {
  background: rgba(255,255,255,0.04);
  border-color: rgba(255,255,255,0.06);
}
.search-form:focus-within {
  background: #fff;
  border-color: var(--red);
  box-shadow: 0 0 0 3px rgba(251,17,20,0.1);
}
.dark-ui .search-form:focus-within {
  background: #181d29;
  border-color: var(--red);
  box-shadow: 0 0 0 3px rgba(251,17,20,0.15);
}
.search-form .ab { color: var(--text-muted); opacity: 0.6; }
.search-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  font-size: 13px;
  font-weight: 500;
  min-width: 0;
}
.dark-ui .search-input { color: #fff; }
.search-clear {
  color: var(--text-muted);
  width: 18px;
  height: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}
.search-clear:hover { background: rgba(0,0,0,0.05); }

/* Nav menu */
.nav-menu { display: flex; gap: 4px; overflow-x: auto; scrollbar-width: none; }
.nav-menu::-webkit-scrollbar { display: none; }
.nav-link {
  padding: 6px 14px;
  color: var(--text);
  font-weight: 700;
  font-size: 13px;
  border-radius: var(--radius-pill);
  transition: all 0.2s var(--ease);
  white-space: nowrap;
  font-family: var(--font-primary);
}
.dark-ui .nav-link { color: rgba(255, 255, 255, 0.8); }
.nav-link:hover { color: var(--red); background: rgba(251,17,20,0.05); }
.dark-ui .nav-link:hover { color: var(--red); background: rgba(255,255,255,0.05); }
.nav-link.is-active {
  background: var(--red);
  color: #fff;
}
.dark-ui .nav-link.is-active {
  background: var(--red);
  color: #fff;
}

/* ─── Section head & titles ───────────────────────────────────────────── */
.section-title { margin: 18px 0 12px; }
.section-title span {
  font-family: var(--font-primary);
  font-size: 15px;
  font-weight: 800;
  text-transform: uppercase;
  color: var(--red);
  letter-spacing: 0.5px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }

/* ─── Featured Slider ─────────────────────────────────────────────────── */
.featured-section { margin-bottom: 24px; }
.featured-slider { position: relative; }
.featured-slider .prev, .featured-slider .next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid var(--border);
  z-index: 10;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s var(--ease);
  box-shadow: var(--shadow-sm);
}
.dark-ui .featured-slider .prev, .dark-ui .featured-slider .next {
  background: rgba(22, 27, 38, 0.85);
  border-color: var(--card-border-dark);
  color: #fff;
}
.featured-slider .prev { left: -18px; }
.featured-slider .next { right: -18px; }
.featured-slider .prev:hover, .featured-slider .next:hover {
  background: var(--red);
  border-color: var(--red);
  color: #fff;
  transform: translateY(-50%) scale(1.05);
}
.slider { display: flex; overflow-x: auto; scrollbar-width: none; gap: 14px; padding: 4px 0 8px; scroll-snap-type: x mandatory; }
.slider::-webkit-scrollbar { display: none; }
.slider-post { flex-shrink: 0; width: 85%; max-width: 360px; scroll-snap-align: start; }
.featured-post {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  aspect-ratio: 16/9;
  box-shadow: var(--shadow-card);
  transition: transform 0.28s var(--ease), box-shadow 0.28s;
  background: #000;
}
.featured-post:hover { transform: translateY(-2px); box-shadow: var(--shadow-card-hover); }
.dark-ui .featured-post:hover { box-shadow: var(--shadow-card-dark-hover); }
.featured-post img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; transition: transform 0.4s var(--ease); }
.featured-post:hover img { transform: scale(1.03); }
.featured-post .title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
  padding: 24px 16px 12px;
}
.featured-post .title h3 {
  color: #fff;
  font-size: 13.5px;
  font-family: var(--font-primary);
  font-weight: 700;
  line-height: 1.3;
}

/* ─── Movie Grid & Cards ──────────────────────────────────────────────── */
.movies-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  margin: 12px 0 24px;
}
@media (min-width: 540px) { .movies-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
@media (min-width: 768px) { .movies-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 20px; } }
@media (min-width: 1024px) { .movies-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); } }

.single-post {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--border);
  transition: transform 0.28s var(--ease), box-shadow 0.28s var(--ease), border-color 0.28s;
  cursor: pointer;
  position: relative;
}
.dark-ui .single-post {
  background: var(--card-bg-dark);
  border-color: var(--card-border-dark);
}
.single-post:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-card-hover);
  border-color: rgba(251,17,20,0.25);
}
.dark-ui .single-post:hover {
  box-shadow: var(--shadow-card-dark-hover);
}
.thumb {
  position: relative;
  aspect-ratio: 2/3;
  overflow: hidden;
  background: #e2e8f0;
}
.dark-ui .thumb { background: #1a202c; }
.thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s var(--ease); }
.single-post:hover .thumb img { transform: scale(1.04); }
.thumb::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(13,15,20,0.6) 0%, transparent 60%);
  pointer-events: none;
}
.thumb .badges {
  position: absolute;
  top: 8px;
  left: 8px;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  z-index: 2;
}
.badge {
  display: inline-block;
  padding: 2px 6px;
  font-size: 9px;
  font-weight: 800;
  border-radius: 4px;
  background: rgba(13,15,20,0.75);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.08);
  font-family: var(--font-primary);
  text-transform: uppercase;
}

/* Card details */
.post-desc { padding: 12px; }
.post-title {
  font-family: var(--font-primary);
  font-weight: 700;
  color: var(--text);
  font-size: 13px;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 2.8em;
}
.dark-ui .post-title { color: #f1f5f9; }
.single-post:hover .post-title { color: var(--red); }
.post-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  padding-top: 8px;
  font-size: 11px;
  color: var(--text-muted);
  border-top: 1px solid var(--border);
  margin-top: 8px;
}
.dark-ui .post-meta { border-top-color: var(--card-border-dark); color: var(--text-muted-dark); }
.post-meta-item { display: inline-flex; align-items: center; gap: 3px; }
.post-meta .dot { opacity: 0.4; }

/* ─── Filters & Pills ─────────────────────────────────────────────────── */
.filters { margin: 6px 0 16px; }
.filters__scroll { display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; padding-bottom: 2px; }
.filters__scroll::-webkit-scrollbar { display: none; }
.pill {
  flex-shrink: 0;
  padding: 5px 14px;
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  font-size: 12px;
  font-weight: 700;
  color: var(--text-muted);
  transition: all 0.2s var(--ease);
  font-family: var(--font-primary);
}
.dark-ui .pill { background: var(--card-bg-dark); border-color: var(--card-border-dark); color: var(--text-muted-dark); }
.pill:hover { color: var(--red); border-color: var(--red); background: rgba(251,17,20,0.03); }
.pill.is-active {
  background: var(--red);
  color: #fff;
  border-color: var(--red);
  box-shadow: 0 4px 10px rgba(251,17,20,0.25);
}

/* ─── Skeletons ───────────────────────────────────────────────────────── */
.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  margin: 12px 0;
}
@media (min-width: 540px) { .skeleton-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
@media (min-width: 768px) { .skeleton-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 20px; } }
@media (min-width: 1024px) { .skeleton-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); } }
.skeleton { background: var(--card-bg); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border); }
.dark-ui .skeleton { background: var(--card-bg-dark); border-color: var(--card-border-dark); }
.skeleton__poster { aspect-ratio: 2/3; background: #e2e8f0; animation: shimmer 1.5s infinite; }
.dark-ui .skeleton__poster { background: #1e293b; }
.skeleton__line { height: 10px; margin: 10px 12px 0; border-radius: 4px; background: #e2e8f0; animation: shimmer 1.5s infinite; }
.dark-ui .skeleton__line { background: #1e293b; }
.skeleton__line:last-child { width: 50%; margin-bottom: 12px; }
.skeleton-modal { min-height: 80vh; background: #e2e8f0; animation: shimmer 1.5s infinite; border-radius: var(--radius); }
.dark-ui .skeleton-modal { background: #1e293b; }
@keyframes shimmer { 0% { opacity: 0.5; } 50% { opacity: 0.85; } 100% { opacity: 0.5; } }

/* ─── Loading more button ────────────────────────────────────────────── */
.view-more { text-align: center; margin: 24px 0 10px; }
#loadMoreBtn {
  padding: 10px 24px;
  border: 1.5px solid var(--red);
  background: transparent;
  color: var(--red);
  border-radius: var(--radius-pill);
  font-family: var(--font-primary);
  font-weight: 700;
  transition: all 0.2s var(--ease);
}
#loadMoreBtn:hover {
  background: var(--red);
  color: #fff;
  transform: translateY(-1px);
}

/* ─── Toast ───────────────────────────────────────────────────────────── */
.toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(24px);
  background: #1e293b;
  color: #f8fafc;
  padding: 10px 20px;
  border-radius: var(--radius-pill);
  font-size: 13px;
  font-weight: 600;
  box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  z-index: 300;
  opacity: 0;
  transition: opacity 0.2s var(--ease), transform 0.25s var(--ease);
}
.toast.is-visible { opacity: 1; transform: translateX(-50%) translateY(0); }
.toast--success { background: #10b981; }
.toast--error { background: #ef4444; }

/* ─── Full-Screen Modal ─── (NO GAPS ON PC) ────────────────────────── */
.modal[hidden] {
  display: none !important;
}
.modal {
  position: fixed !important;
  inset: 0 !important;
  z-index: 100 !important;
  display: flex;
  align-items: stretch !important;
  justify-content: stretch !important;
  padding: 0 !important;
}
.modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(13, 15, 20, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.modal__card {
  position: relative !important;
  background: var(--card-bg) !important;
  width: 100vw !important;
  max-width: 100vw !important;
  height: 100vh !important;
  max-height: 100vh !important;
  overflow-y: auto !important;
  z-index: 2 !important;
  box-shadow: none !important;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 0 !important;
}
.dark-ui .modal__card { background: var(--bg-dark) !important; }

/* Float back close button */
.modal__close {
  position: fixed;
  top: 16px;
  left: 16px;
  z-index: 120;
  width: 40px;
  height: 40px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  transition: all 0.2s;
  box-shadow: 0 4px 10px rgba(0,0,0,0.3);
}
.modal__close:hover {
  background: var(--red);
  border-color: var(--red);
  transform: scale(1.08);
}

.modal__body {
  width: 100%;
  max-width: 100%;
  padding: 0;
}

/* ─── Premium Poster Background Hero Section ─────────────────────────── */
.movie-hero {
  position: relative;
  min-height: 460px;
  display: flex;
  align-items: flex-end;
  background-image: var(--hero-bg, none);
  background-size: cover;
  background-position: center 25%;
  background-repeat: no-repeat;
  margin-top: 0;
  width: 100%;
}
.movie-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(13, 15, 20, 0.95) 6%, rgba(13, 15, 20, 0.8) 55%, rgba(13, 15, 20, 0.4) 100%);
  z-index: 1;
}
.dark-ui .movie-hero__overlay {
  background: linear-gradient(to top, rgba(13, 15, 20, 0.98) 6%, rgba(13, 15, 20, 0.88) 55%, rgba(13, 15, 20, 0.4) 100%);
}

@media (min-width: 768px) {
  .movie-hero {
    min-height: 520px;
    background-position: center 20%;
  }
  .movie-hero__overlay {
    background: linear-gradient(to right, rgba(13, 15, 20, 0.96) 35%, rgba(13, 15, 20, 0.75) 70%, rgba(13, 15, 20, 0.2) 100%),
                linear-gradient(to top, rgba(13, 15, 20, 0.8) 4%, transparent 20%);
  }
  .dark-ui .movie-hero__overlay {
    background: linear-gradient(to right, rgba(13, 15, 20, 0.98) 35%, rgba(13, 15, 20, 0.85) 70%, rgba(13, 15, 20, 0.2) 100%),
                linear-gradient(to top, rgba(13, 15, 20, 0.8) 4%, transparent 20%);
  }
}

.movie-hero__content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: var(--maxw);
  margin: 0 auto;
  padding: 90px 24px 36px;
}
.movie-hero__info {
  max-width: 640px;
}
.movie-hero__title {
  font-family: var(--font-primary);
  font-size: clamp(20px, 4.5vw, 32px);
  font-weight: 900;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 12px;
  text-shadow: 0 2px 10px rgba(0,0,0,0.5);
}
.movie-hero__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 18px;
}
.chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 9px;
  border-radius: var(--radius-pill);
  font-size: 11px;
  font-weight: 700;
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.9);
  border: 1px solid rgba(255,255,255,0.15);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}
.chip--imdb { background: rgba(245,197,24,0.22); border-color: rgba(245,197,24,0.35); color: var(--gold); }
.chip--quality { background: rgba(239,68,68,0.2); border-color: rgba(239,68,68,0.35); color: #f87171; }

.movie-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.hero-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 18px;
  border-radius: var(--radius-pill);
  font-family: var(--font-primary);
  font-weight: 700;
  font-size: 13px;
  transition: all 0.2s;
  cursor: pointer;
  border: none;
}
.hero-btn--primary { background: var(--red); color: #fff; box-shadow: 0 4px 12px rgba(251,17,20,0.3); }
.hero-btn--primary:hover { background: var(--red-dark); transform: translateY(-1px); }
.hero-btn--ghost {
  background: rgba(255,255,255,0.15);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.2);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}
.hero-btn--ghost:hover { background: rgba(255,255,255,0.25); transform: translateY(-1px); }
.hero-btn--fav[data-fav="1"] { background: rgba(251,191,36,0.2); border-color: rgba(251,191,36,0.35); color: var(--gold); }

/* Movie Info Grid */
.movie-detail-body {
  max-width: var(--maxw);
  margin: 0 auto;
  padding: 24px 20px 48px;
}
.movie-info-cols {
  display: flex;
  flex-direction: column;
  gap: 24px;
  margin-bottom: 24px;
}
@media (min-width: 768px) {
  .movie-info-cols {
    flex-direction: row;
    align-items: flex-start;
  }
}
.movie-info-poster {
  flex-shrink: 0;
  width: 180px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--border);
  background: var(--card-bg);
}
.dark-ui .movie-info-poster {
  border-color: var(--card-border-dark);
  background: var(--card-bg-dark);
}
.movie-info-poster img {
  width: 100%;
  height: auto;
  display: block;
}
.movie-info-details {
  flex: 1;
  min-width: 0;
}
.movie-info-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  margin-bottom: 24px;
  padding: 16px;
  background: #f1f5f9;
  border-radius: var(--radius-lg);
}
.dark-ui .movie-info-grid { background: rgba(255,255,255,0.02); }
.movie-info-row { display: flex; gap: 12px; font-size: 13px; }
.movie-info-row strong { width: 90px; flex-shrink: 0; font-weight: 700; color: var(--text); font-family: var(--font-primary); }
.dark-ui .movie-info-row strong { color: var(--text-dark); }
.movie-info-row span { color: var(--text-muted); }
.dark-ui .movie-info-row span { color: var(--text-muted-dark); }

/* Storyline */
.movie-storyline { margin-bottom: 24px; padding: 16px; background: #f1f5f9; border-radius: var(--radius-lg); }
.dark-ui .movie-storyline { background: rgba(255,255,255,0.02); }
.movie-storyline-label { font-family: var(--font-primary); font-weight: 800; font-size: 12px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
.movie-storyline p { font-size: 13.5px; line-height: 1.6; color: var(--text-muted); }
.dark-ui .movie-storyline p { color: var(--text-muted-dark); }

/* Section Title */
.post-section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-primary);
  font-size: 13.5px;
  font-weight: 800;
  text-transform: uppercase;
  color: var(--text);
  margin: 28px 0 14px;
  padding-bottom: 8px;
  border-bottom: 1.5px solid var(--border);
}
.dark-ui .post-section-title { color: var(--text-dark); border-bottom-color: var(--card-border-dark); }
.post-section-title::before { font-size: 14px; }
.post-section-title.download::before { content: '🎬'; }
.post-section-title.screenshots::before { content: '🖼️'; }

/* ─── Grid-Based Big Screenshot view ────────────────────────────────── */
.screenshots {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin: 12px 0 24px;
}
@media (min-width: 600px) {
  .screenshots {
    grid-template-columns: repeat(2, 1fr);
  }
}
.screenshot {
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  transition: transform 0.25s var(--ease), box-shadow 0.25s;
  aspect-ratio: 16/9;
}
.dark-ui .screenshot { border-color: var(--card-border-dark); }
.screenshot:hover { transform: scale(1.015); box-shadow: var(--shadow-card); }
.screenshot img { width: 100%; height: 100%; object-fit: cover; }

/* ─── Minimalist Polished Download Grid ────────────────────────────── */
.download-sections { display: flex; flex-direction: column; gap: 16px; }
.dl-group {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.dark-ui .dl-group { background: var(--card-bg-dark); border-color: var(--card-border-dark); }
.dl-group__title {
  font-family: var(--font-primary);
  font-weight: 800;
  font-size: 12.5px;
  padding: 12px 16px;
  background: rgba(0,0,0,0.02);
  border-bottom: 1px solid var(--border);
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 8px;
}
.dark-ui .dl-group__title { background: rgba(255,255,255,0.02); border-bottom-color: var(--card-border-dark); color: var(--text-dark); }
.dl-group__title::before { content: '📂'; }

.dl-group__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
  gap: 12px;
  padding: 16px;
}
@media (max-width: 480px) { .dl-group__grid { grid-template-columns: repeat(2, 1fr); } }

/* Single Minimalist Download Button */
.dl-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14px 10px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: var(--radius);
  color: #334155;
  transition: all 0.2s var(--ease);
  min-height: 72px;
  text-align: center;
}
.dark-ui .dl-btn {
  background: rgba(255,255,255,0.02);
  border-color: rgba(255,255,255,0.06);
  color: #e2e8f0;
}
.dl-btn:hover {
  transform: translateY(-2px);
  border-color: var(--red);
  background: #fff;
  box-shadow: 0 6px 15px rgba(251,17,20,0.08);
}
.dark-ui .dl-btn:hover {
  background: #1d2331;
  box-shadow: 0 6px 18px rgba(251,17,20,0.12);
}
.dl-btn:active { transform: scale(0.96); }

.dl-btn__quality {
  font-size: 13.5px;
  font-weight: 800;
  letter-spacing: 0.5px;
  font-family: var(--font-primary);
}
.dl-btn__size {
  font-size: 10.5px;
  color: var(--text-muted);
  margin-top: 3px;
  font-weight: 500;
}
.dark-ui .dl-btn__size { color: var(--text-muted-dark); }

/* Remove legacy color variations */
.dl-btn--sd, .dl-btn--hd, .dl-btn--fhd, .dl-btn--uhd { background: inherit; color: inherit; border-color: inherit; }
.dark-ui .dl-btn--sd, .dark-ui .dl-btn--hd, .dark-ui .dl-btn--fhd, .dark-ui .dl-btn--uhd { background: inherit; color: inherit; border-color: inherit; }

/* ─── Bottom Sheet ────────────────────────────────────────────────────── */
.sheet { position: fixed; inset: 0; z-index: 110; display: flex; align-items: flex-end; justify-content: center; }
.sheet__backdrop { position: absolute; inset: 0; background: rgba(13,15,20,0.7); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
.sheet__panel {
  position: relative;
  background: var(--card-bg);
  border-radius: 24px 24px 0 0;
  width: 100%;
  max-width: 500px;
  padding: 14px 20px 32px;
  border-top: 1px solid var(--border);
  box-shadow: 0 -8px 30px rgba(0,0,0,0.15);
  max-height: 80vh;
  overflow-y: auto;
  z-index: 2;
}
.dark-ui .sheet__panel { background: var(--card-bg-dark); border-top-color: var(--card-border-dark); }
.sheet__handle { width: 36px; height: 4px; background: var(--border); border-radius: 10px; margin: 0 auto 16px; }
.dark-ui .sheet__handle { background: rgba(255,255,255,0.15); }
.sheet__title { font-size: 16px; font-weight: 900; margin-bottom: 4px; font-family: var(--font-primary); }
.sheet__hint { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; }
.dark-ui .sheet__hint { color: var(--text-muted-dark); }
.sheet__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); gap: 10px; margin-bottom: 18px; }
.sheet__btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 12px 6px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  font-size: 11px;
  font-weight: 700;
  text-align: center;
  transition: all 0.2s;
}
.dark-ui .sheet__btn { background: rgba(255,255,255,0.03); border-color: var(--card-border-dark); }
.sheet__btn:hover { border-color: var(--red); color: var(--red); transform: translateY(-1px); }
.sheet__btn-icon { width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; font-size: 20px; }
.sheet__url { display: flex; gap: 8px; margin-bottom: 12px; }
.sheet__url input { flex: 1; min-width: 0; padding: 8px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 11px; outline: none; }
.dark-ui .sheet__url input { background: rgba(255,255,255,0.02); border-color: var(--card-border-dark); color: var(--text-dark); }
.sheet__tip { font-size: 11px; color: var(--text-muted); text-align: center; padding: 8px 12px; background: var(--bg); border-radius: var(--radius); }
.dark-ui .sheet__tip { background: rgba(255,255,255,0.02); color: var(--text-muted-dark); }

/* ─── Dashboard ───────────────────────────────────────────────────────── */
.dashboard { display: flex; flex-direction: column; gap: 16px; padding: 16px 0; }
.dash-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
.dash-stat { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 16px; text-align: center; }
.dark-ui .dash-stat { background: var(--card-bg-dark); border-color: var(--card-border-dark); }
.dash-stat .num { font-size: 24px; font-weight: 800; color: var(--red); display: block; font-family: var(--font-primary); margin-bottom: 4px; }
.dash-stat .label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; }
.dark-ui .dash-stat .label { color: var(--text-muted-dark); }

.dash-section { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
.dark-ui .dash-section { background: var(--card-bg-dark); border-color: var(--card-border-dark); }
.dash-section h3 { font-size: 13.5px; font-weight: 800; padding: 12px 16px; border-bottom: 1px solid var(--border); font-family: var(--font-primary); }
.dark-ui .dash-section h3 { border-bottom-color: var(--card-border-dark); }

.dash-list { display: flex; flex-direction: column; }
.dash-item { display: flex; align-items: center; gap: 12px; padding: 10px 16px; border-bottom: 1px solid var(--border); cursor: pointer; }
.dark-ui .dash-item { border-bottom-color: var(--card-border-dark); }
.dash-item:last-child { border-bottom: none; }
.dash-item__poster { width: 36px; height: 50px; border-radius: var(--radius-sm); overflow: hidden; background: var(--border); }
.dash-item__poster img { width: 100%; height: 100%; object-fit: cover; }
.dash-item__body { flex: 1; min-width: 0; }
.dash-item__title { font-size: 13px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-family: var(--font-primary); }
.dash-item__meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.dash-item__action { font-size: 11px; color: var(--red); font-weight: 700; }

.url-list { display: flex; flex-direction: column; }
.url-item { display: flex; align-items: center; gap: 10px; padding: 10px 16px; border-bottom: 1px solid var(--border); font-size: 11px; }
.dark-ui .url-item { border-bottom-color: var(--card-border-dark); }
.url-item__quality { padding: 2px 6px; background: var(--red); color: #fff; border-radius: 4px; font-weight: 800; font-size: 9px; font-family: var(--font-primary); }
.url-item__url { flex: 1; min-width: 0; font-family: monospace; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.url-item__copy { padding: 4px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 10px; font-weight: 700; cursor: pointer; }
.dark-ui .url-item__copy { background: rgba(255,255,255,0.05); border-color: var(--card-border-dark); color: var(--text-dark); }

/* ─── Footer ──────────────────────────────────────────────────────────── */
footer {
  background: #090b0e;
  color: #64748b;
  margin-top: 40px;
  border-top: 1px solid rgba(255,255,255,0.03);
}
.footer-inner {
  max-width: var(--maxw);
  margin: 0 auto;
  padding: 32px 20px 24px;
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}
@media (min-width: 600px) { .footer-inner { grid-template-columns: 1.5fr 1fr; } }
.footer-brand { display: flex; flex-direction: column; gap: 8px; }
.footer-logo { height: 28px; width: auto; opacity: 0.8; }
.footer-tagline { font-size: 12px; color: #475569; max-width: 280px; }
.footer-tg {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 14px;
  background: rgba(30,136,229,0.08);
  border: 1px solid rgba(30,136,229,0.2);
  border-radius: var(--radius-pill);
  color: #42a5f5;
  font-size: 12px;
  font-weight: 700;
  width: fit-content;
}
.footer-nav h4 { font-size: 11px; font-weight: 800; text-transform: uppercase; color: #94a3b8; margin-bottom: 12px; font-family: var(--font-primary); }
.footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.footer-nav a { color: #475569; font-size: 12.5px; transition: color 0.2s; }
.footer-nav a:hover { color: var(--red); }
.footer-bottom { border-top: 1px solid rgba(255,255,255,0.02); padding: 16px 20px; text-align: center; }
.footer-brand-pill { background: var(--red); color: #fff; font-family: var(--font-primary); font-weight: 800; font-size: 12px; padding: 4px 14px; border-radius: var(--radius-pill); display: inline-block; margin-bottom: 8px; }
.footer-copyright { font-size: 11px; color: #334155; }

/* ─── Go-to-top ───────────────────────────────────────────────────────── */
#go-top {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 38px;
  height: 38px;
  background: var(--red);
  color: #fff;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: all 0.2s var(--ease);
  z-index: 40;
  box-shadow: 0 4px 10px rgba(251,17,20,0.3);
}
#go-top.is-visible { opacity: 1; pointer-events: auto; }
#go-top:hover { transform: translateY(-2px); }

/* ─── Responsive Media Queries ────────────────────────────────────────── */
@media (max-width: 768px) {
  .header-brand { padding: 10px 16px; }
  .header-logo img { height: 32px; }
  .menu-toggle { display: inline-flex; }
  .header-brand { display: flex; align-items: center; justify-content: space-between; width: 100%; }
  .header-logo { margin-right: auto; }
  .nav-bar__inner { flex-direction: column; align-items: stretch; gap: 8px; padding: 8px 16px 12px; }
  .search-form { max-width: 100%; width: 100%; }
  
  .nav-menu {
    display: none;
    flex-direction: column;
    width: 100%;
    gap: 4px;
    padding: 8px 0;
    border-top: 1px solid var(--border);
    margin-top: 4px;
  }
  .dark-ui .nav-menu { border-top-color: var(--card-border-dark); }
  .nav-menu.is-open { display: flex; }
  .nav-link { width: 100%; padding: 8px 14px; border-radius: var(--radius-sm); }
  
  .movie-hero { min-height: 360px; }
  .movie-hero__content { padding: 60px 16px 24px; }
  .movie-hero__title { font-size: 22px; }
  
  .movie-detail-body { padding: 16px 16px 36px; }
  .post-section-title { font-size: 12.5px; margin: 20px 0 12px; }
  .dl-group__title { font-size: 12px; padding: 10px 14px; }
}

@media (max-width: 480px) {
  .header-controls { gap: 10px; }
  .notice-strip marquee, #noticeMarquee { padding-left: 70px; font-size: 11px; }
  .notice-strip-label { font-size: 9px; padding: 0 8px; }
  .movies-grid { gap: 12px; }
  .post-title { font-size: 12px; min-height: 2.8em; }
  .post-meta { font-size: 10px; }
  
  .movie-hero { min-height: 300px; }
  .movie-hero__content { padding: 40px 12px 16px; }
  .movie-hero__title { font-size: 18px; }
  .movie-hero__chips { margin-bottom: 12px; }
  .hero-btn { padding: 8px 14px; font-size: 12px; }
  
  .dl-btn { min-height: 60px; padding: 10px 6px; }
  .dl-btn__quality { font-size: 12.5px; }
  .dl-btn__size { font-size: 9.5px; }
}
